                Work_address = "Kapital Bank",
                Salary = 2000
            };

            CREDIT credit = new CREDIT
            {
                Client = client,
                Amount = 10000,
                Percent = 10,
                Months = 12
            };

            WORKER worker1 = new WORKER
            {
                Name = "Samir",
                Surname = "Hasanov",
                Salary = 1200
            };

            WORKER worker2 = new WORKER
            {
                Name = "Rashad",
                Surname = "Kerimov",
                Salary = 1500
            };

            MANAGER manager = new MANAGER
            {
                Name = "Nicat",
                Surname = "Mammadli",
                Salary = 2500
            };

            BANK bank = new BANK
            {
                Name = "My Bank",
