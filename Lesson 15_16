    //Bank=>NAME, BUDGET, PROFIT, CALCULATE_PROFIT), CEO, WORKER[], MANAGER[], CLIENT[], showClientCredit(string fullname), payCredit (Client, money), showAllCredit
    class BANK
    {
        public string Name { get; set; }
        public decimal Budget { get; set; }
        public decimal Profit { get; set; }
        public CEO Ceo { get; set; }

        public List<WORKER> Workers { get; set; } = new();

        public List<MANAGER> Managers { get; set; } = new();

        public List<CLIENT> Clients { get; set; } = new();

        public List<CREDIT> Credits { get; set; } = new();

        public decimal CalculateProfit()
        {
            decimal totalSalaries = 0;

            foreach (var worker in Workers)
            {
                totalSalaries += worker.Salary;
            }

            foreach (var manager in Managers)
            {
                totalSalaries += manager.Salary;
            }

            totalSalaries += Ceo.Salary;

            Profit = Budget - totalSalaries;

            return Profit;
        }

        public void ShowClientCredit(string fullname)
        {
            foreach(var credit in Credits)
            {
                string clientFullName = credit.Client.Name + " " + credit.Client.Surname;

                if (clientFullName == fullname)
                {
                    Console.WriteLine($"{clientFullName} credit amount:{credit.Amount}");
                }
            }
        }

        public void PayCredit(CLIENT client, decimal money)
        {
            foreach (var credit in Credits)
            {
                if (credit.Client == client)
                {
                    credit.Amount -= money;
                    Budget += money;
                      
                    Console.WriteLine($"{client.Name} paid {money} AZN.");
                    Console.WriteLine($"Remaining debt: {credit.Amount} AZN.");

                    return;
                }
            }

            Console.WriteLine("Credit not found.");
        }

        public void ShowAllCredit()
        {
            foreach (var credit in Credits)
            {
                Console.WriteLine(
                    $"{credit.Client.Name} {credit.Client.Surname} - {credit.Amount} AZN"
                );
            }
        }
    }


