class Animal
{

    public string Nickname { get; set; }

    public int Age { get; set; }

    public string Gender { get; set; }

    public int Energy { get; set; }

    public double Price { get; set; }

    public int MealQuantity { get; set; }



    public Animal(
        string nickname,
        int age,
        string gender,
        int energy,
        double price
    )
    {
        Nickname = nickname;

        Age = age;

        Gender = gender;

        Energy = energy;

        Price = price;

        MealQuantity = 0;
    }




    public void Eat()
    {
        Console.WriteLine( Nickname + " is eating" );

        Energy += 20;

        MealQuantity++;

        Price += 5;

        Age += 1;

        if (Energy > 100)
        {
            Energy = 100;
        }

        Console.WriteLine( "Energy: " + Energy );
    }



    public void Sleep()
    {
        Console.WriteLine( Nickname + " is sleeping" );

        Energy += 40;

        if (Energy > 100)
        {
            Energy = 100;
        }

        Console.WriteLine( "Energy restored: " +Energy );
    }




    public void Play()
    {
        Console.WriteLine( Nickname + " started playing" );

        Energy -= 30;

        if (Energy < 0)
        {
            Energy = 0;
        }

        Console.WriteLine( "Energy left: " + Energy);



        if (Energy == 0)
        {
            Console.WriteLine( Nickname + " is too tired" );

            Sleep();
        }
    }




    public void Show()
    {
        Console.WriteLine();

        Console.WriteLine( "Nickname: " + Nickname );

        Console.WriteLine( "Age: " + Age );

        Console.WriteLine( "Gender: " + Gender );

        Console.WriteLine( "Energy: " + Energy );

        Console.WriteLine( "Price: " + Price );

        Console.WriteLine( "Meal Count: " + MealQuantity );

        Console.WriteLine();
    }
}



