// biredn cox pisik saxlamaq ucun List istifade etdim.
// sonradan rahatliqla elave ve silmek ede bilim deye.
class PetShop
{
    public List<Cat> Cats =
        new List<Cat>();

    public List<Dog> Dogs =
        new List<Dog>();

    public List<Bird> Birds =
        new List<Bird>();

    public List<Fish> Fishes =
        new List<Fish>();



    public void RemoveByNickName(
        string nickname
    )
    {
        Cats.RemoveAll( x => x.Nickname == nickname );

        Dogs.RemoveAll( x => x.Nickname == nickname );

        Birds.RemoveAll( x => x.Nickname == nickname );

        Fishes.RemoveAll( x => x.Nickname == nickname );

        Console.WriteLine( nickname + " removed" );
    }


// foreach istifade etdim bu hissede cunki siyahidaki
// butun elementlerin uzerinden kecmek lazimdir.
    public int TotalMeals()
    {
        int total = 0;

        foreach (
            var cat
            in Cats
        )
        {
            total +=
                cat.MealQuantity;
        }

        foreach (
            var dog
            in Dogs
        )
        {
            total +=
                dog.MealQuantity;
        }

        foreach (
            var bird
            in Birds
        )
        {
            total +=
                bird.MealQuantity;
        }

        foreach (
            var fish
            in Fishes
        )
        {
            total +=
                fish.MealQuantity;
        }

        return total;
    }




    public double TotalPrice()
    {
        double total = 0;

        foreach (
            var cat
            in Cats
        )
        {
            total +=
                cat.Price;
        }

        foreach (
            var dog
            in Dogs
        )
        {
            total +=
                dog.Price;
        }

        foreach (
            var bird
            in Birds
        )
        {
            total +=
                bird.Price;
        }

        foreach (
            var fish
            in Fishes
        )
        {
            total +=
                fish.Price;
        }

        return total;
    }



    public void ShowAll()
    {
        foreach (
            var cat
            in Cats
        )
        {
            cat.Show();
        }

        foreach (
            var dog
            in Dogs
        )
        {
            dog.Show();
        }

        foreach (
            var bird
            in Birds
        )
        {
            bird.Show();
        }

        foreach (
            var fish
            in Fishes
        )
        {
            fish.Show();
        }
    }
}




