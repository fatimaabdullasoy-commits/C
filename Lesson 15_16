    //Manager => GUID, name, surname, age, position, salary, organize(), calculatesalaries()
    class MANAGER 
    {
        public Guid Id { get; set; } = Guid.NewGuid();

        public string Name { get; set; }
        public string Surname { get; set; }
        public int Age { get; set; }
