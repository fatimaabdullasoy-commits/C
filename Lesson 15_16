    }

    //Credit => GUID, Client, amount, percent, months, calculatePercent, payment)
    class CREDIT
    {
        public Guid Id { get; set; } = Guid.NewGuid();

        public CLIENT Client { get; set; }
        public decimal Amount { get; set; }
        public double Percent { get; set; }
        public int Months { get; set; }

        public decimal CalculatePercent()
        {
            return Amount * (decimal)(Percent / 100);
        }

        public decimal Payment()
        {
            if (Months == 0)
                return 0;

            decimal total = Amount + CalculatePercent();
            return total / Months;
        }

    }

    //Client=>GUID, name, surname, age, live_address, work_address, salary
    class CLIENT
    {
        public Guid Id { get; set; } = Guid.NewGuid();

        public string Name { get; set; }
        public string Surname { get; set; }
        public int Age { get; set; }
        public string Live_address { get; set; }
        public string Work_address { get; set; }
        public decimal Salary { get; set; }

    }


    class Program
