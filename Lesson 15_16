                Ceo = ceo
            };

            bank.Workers.Add(worker1);
            bank.Workers.Add(worker2);

            bank.Managers.Add(manager);

            bank.Clients.Add(client);

            bank.Credits.Add(credit);

            Console.WriteLine($"Bank profit: {bank.CalculateProfit()}");

            bank.ShowAllCredit();

            bank.PayCredit(client, 2000);

            bank.ShowAllCredit();
        }
    }
